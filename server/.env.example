# LINE Bot Credentials
# Get these from https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# Server Config
PORT=3000

# Claude Code Config
# Working directory for Claude Code CLI (optional, defaults to home directory)
CLAUDE_WORK_DIR=
# Max timeout in milliseconds for Claude Code response (default: 120000 = 2 min)
CLAUDE_TIMEOUT=120000
